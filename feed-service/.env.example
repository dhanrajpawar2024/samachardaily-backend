# ============================================================
# Feed Service Configuration
# ============================================================

# Server
PORT=3003
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=samachar_daily
POSTGRES_USER=sd_user
POSTGRES_PASSWORD=sd_secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=3

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=feed-service-group
KAFKA_TOPIC_INTERACTIONS=interactions
KAFKA_TOPIC_FEED_INVALIDATION=feed_invalidation

# Content Service
CONTENT_SERVICE_URL=http://content-service:3002

# JWT for service-to-service auth
JWT_SECRET=same-as-auth-service-secret

# Feed Algorithm Configuration
FEED_CACHE_TTL_MINUTES=5
FEED_SIZE=50
RECENCY_WEIGHT=0.20
TRENDING_WEIGHT=0.30
AFFINITY_WEIGHT=0.40
ENGAGEMENT_WEIGHT=0.10
MIN_AFFINITY_THRESHOLD=0.1
