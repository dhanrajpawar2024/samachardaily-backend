# ============================================================
# Content Service Configuration
# ============================================================

# Server
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=samachar_daily
POSTGRES_USER=sd_user
POSTGRES_PASSWORD=sd_secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=2

# NewsAPI
NEWSAPI_KEY=your-newsapi-key
NEWSAPI_BASE_URL=https://newsapi.org/v2

# RSS Feeds (comma-separated)
RSS_FEEDS=https://feeds.reuters.com/reuters/india,https://feeds.news18.com/rss/hindi

# Ingestion Settings
INGESTION_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FETCH=100
ARTICLE_RETENTION_DAYS=30
LANGUAGE_AUTO_DETECT=true

# JWT for service-to-service auth
JWT_SECRET=same-as-auth-service-secret

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_ARTICLE_CREATED=articles.created
KAFKA_TOPIC_ARTICLE_UPDATED=articles.updated
