# ============================================================
# Recommendation Service — Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3006
NODE_ENV=development

# ── PostgreSQL (shared instance) ────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=samachar_daily
POSTGRES_USER=sd_user
POSTGRES_PASSWORD=sd_secret

# ── Redis (DB 6 reserved for Recommendation Service) ─────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=6

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=recommendation-service
KAFKA_GROUP_ID=recommendation-service-group
KAFKA_TOPIC_CLICKSTREAM=clickstream

# ── JWT Authentication ─────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
