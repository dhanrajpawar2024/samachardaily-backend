# ============================================================
#  SamacharDaily — GCP Production .env
#  Copy this to .env on your GCP VM and fill in real values.
#  NEVER commit this file to git.
# ============================================================

# ── GCP VM External IP (get from GCP Console → VM Instances) ──
GCP_EXTERNAL_IP=YOUR_VM_EXTERNAL_IP

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=samachar_daily
POSTGRES_USER=sd_user
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── Elasticsearch ───────────────────────────────────────────
ES_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_TO_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_TO_ANOTHER_RANDOM_64_CHAR_STRING

# ── App ─────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://YOUR_VM_EXTERNAL_IP:4000

# ── Scraper ─────────────────────────────────────────────────
CRON_SCRAPE=*/30 * * * *
CRON_TRENDING=*/15 * * * *
RSS_CONCURRENCY=8
MAX_INGEST_PER_RUN=500

# ── Optional: Google OAuth (fill if using auth) ─────────────
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Optional: Firebase push notifications ───────────────────
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
