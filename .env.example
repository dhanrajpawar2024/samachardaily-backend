# ============================================================
#  SamacharDaily — Environment Variables
#  Copy this to .env and fill in real values before running.
#  NEVER commit .env to git.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=samachar_daily
POSTGRES_USER=sd_user
POSTGRES_PASSWORD=sd_secret
DATABASE_URL=postgresql://sd_user:sd_secret@localhost:5432/samachar_daily

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9094
KAFKA_CLIENT_ID=samachar-daily
KAFKA_GROUP_ID=sd-consumers

# Kafka Topics
KAFKA_TOPIC_CLICKSTREAM=clickstream
KAFKA_TOPIC_ARTICLE_INGESTION=article_ingestion
KAFKA_TOPIC_BREAKING_NEWS=breaking_news
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification_events
KAFKA_TOPIC_FEED_INVALIDATION=feed_invalidation

# ── Elasticsearch ───────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=elastic_secret
ES_INDEX_ARTICLES=sd_articles
ES_INDEX_VIDEOS=sd_videos

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_strong_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Firebase Admin SDK ──────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ── AWS S3 / CloudFront ─────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=samachar-daily-media
CLOUDFRONT_BASE_URL=https://dxxxxx.cloudfront.net

# ── NewsAPI ─────────────────────────────────────────────────
NEWS_API_KEY=your-newsapi-org-key
NEWS_API_BASE_URL=https://newsapi.org/v2

# ── Service Ports ───────────────────────────────────────────
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_CONTENT=3002
PORT_FEED=3003
PORT_SEARCH=3004
PORT_NOTIFICATION=3005

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=*

# ── AdMob / Ad Manager ──────────────────────────────────────
ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

